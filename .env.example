PROJECT_NAME=SmartFeed Backend
ENVIRONMENT=local

BACKEND_PORT=8000
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

POSTGRES_DB=smartfeed
POSTGRES_USER=smartfeed
POSTGRES_PASSWORD=smartfeed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://smartfeed:smartfeed@postgres:5432/smartfeed

MONGO_INITDB_ROOT_USERNAME=smartfeed
MONGO_INITDB_ROOT_PASSWORD=smartfeed
MONGO_DB=smartfeed
MONGODB_URL=mongodb://smartfeed:smartfeed@mongo:27017/smartfeed?authSource=admin
MONGO_RAW_EVENTS_COLLECTION=raw_user_events

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_USER_EVENTS_TOPIC=smartfeed.user_events
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_STARTING_OFFSETS=latest
SPARK_CHECKPOINT_DIR=/opt/spark/work-dir/data/checkpoints/structured_streaming
SPARK_OUTPUT_BASE=/opt/spark/work-dir/data/streaming
SPARK_PROCESSING_TIME=10 seconds
POSTGRES_JDBC_URL=jdbc:postgresql://postgres:5432/smartfeed
RECOMMENDATION_TOP_N=10
RECOMMENDATION_MIN_EVENTS=5
RECOMMENDATION_MODEL_VERSION=als-v1
JUPYTER_TOKEN=smartfeed
